---
import Layout from '@/layouts/Layout.astro';

const title = 'Our Mission & Values: SoundIn';
const description = 'SoundIn is the company behind Holocron. One product, one founder, one standard of care — from the Scottish Highlands.';

const sections = [
  {
    heading: 'Our Mission',
    body: [
      "I started SoundIn because I believed there was a better way to run a nightclub than a pile of spreadsheets and WhatsApp groups. Holocron is the product I wish had existed when I was on the floor — one place for attendance, incidents, guest lists, ticketing, and settlements, built around how venues actually operate.",
    ],
  },
  {
    heading: 'Highland Roots',
    body: [
      "I built this from the Scottish Highlands because that's where I live. Not as a brand story, but as a fact that shapes how I see time, scope, and what good work actually means.",
      "You don't build slowly here by accident. The distance from the noise is a feature. It keeps me honest about what I take on and who I take it on for.",
    ],
  },
  {
    heading: 'Our Approach',
    body: [
      "Solo doesn't mean small. It means I have to be deliberate — deliberate about what goes in the product, deliberate about who I work with, deliberate about every hour spent.",
      "The compliance moat that makes Holocron defensible isn't a feature list. It's a perspective on what nightlife operators actually need — and that perspective comes from being closer to the problem than anyone building from a desk in London.",
    ],
  },
  {
    heading: 'Values',
    body: [
      "Say what you mean. Charge what the work costs. Own your mistakes. Take on less so you can do more with it. Build things that outlast the brief. Care about the people on the other side of every contract, and about the communities they operate in.",
      "That's not a values framework. That's just how I prefer to work.",
    ],
  },
];

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  '@id': 'https://soundin.scot/vision#webpage',
  url: 'https://soundin.scot/vision',
  name: title,
  description,
  isPartOf: { '@id': 'https://soundin.scot/#organization' },
};
---

<Layout
  title={title}
  description={description}
  canonical="https://soundin.scot/vision"
  current="vision"
  skipLink={{ href: '#vision-content', label: 'Skip to content' }}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(aboutSchema)} slot="head" />

  <main class="essay" id="vision-content" tabindex="-1">
    <header class="essay-head">
      <h1>Mission &amp; Values</h1>
    </header>

    <blockquote class="essay-lead">
      <p>&ldquo;I&rsquo;d rather do fewer things properly than chase every brief that comes through the door.&rdquo;</p>
      <cite>Cougar Macdougall, Founder, SoundIn</cite>
    </blockquote>

    {sections.map((s) => (
      <div class="essay-section">
        <h2>{s.heading}</h2>
        <div class="essay-body">
          {s.body.map((p) => <p>{p}</p>)}
        </div>
      </div>
    ))}

    <div class="essay-close">
      <p>Running a venue? <a href="/contact">Get in touch &rarr;</a></p>
    </div>
  </main>
</Layout>

<style>
  .essay {
    max-width: 700px;
    margin: 0 auto;
    padding: 180px 32px 120px;
  }

  .essay-head {
    margin-bottom: 56px;
  }

  .essay-head h1 {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    font-size: clamp(40px, 5vw, 64px);
    line-height: 1.05;
    color: var(--color-snow);
  }

  .essay-lead {
    margin: 0 0 72px;
    padding: 0 0 0 20px;
    border-left: 2px solid var(--color-salmon);
  }

  .essay-lead p {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    font-size: clamp(19px, 2.4vw, 26px);
    line-height: 1.45;
    color: var(--color-snow);
    margin-bottom: 10px;
    text-wrap: balance;
  }

  .essay-lead cite {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
    font-style: normal;
  }

  .essay-section {
    padding: 48px 0;
    border-top: 1px solid var(--color-ghost);
  }

  .essay-section h2 {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    font-size: clamp(22px, 2.8vw, 32px);
    color: var(--color-snow);
    margin-bottom: 20px;
    line-height: 1.2;
  }

  .essay-body p {
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.75;
    color: var(--color-cream);
    margin-bottom: 16px;
  }

  .essay-body p:last-child { margin-bottom: 0; }

  .essay-close {
    padding: 48px 0;
    border-top: 1px solid var(--color-ghost);
  }

  .essay-close p {
    font-family: var(--font-sans);
    font-size: 16px;
    color: var(--color-muted);
  }

  .essay-close a {
    color: var(--color-salmon);
    border-bottom: 1px solid rgba(255, 127, 107, 0.3);
    transition: border-color 0.3s ease;
  }

  .essay-close a:hover { border-bottom-color: var(--color-salmon); }

  .essay-close a:focus-visible {
    outline: 2px solid var(--color-salmon);
    outline-offset: 3px;
    border-radius: 2px;
  }

  @media (max-width: 600px) {
    .essay { padding: 140px 24px 80px; }
    .essay-lead { margin-bottom: 56px; }
  }
</style>
