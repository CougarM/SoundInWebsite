---
import Layout from '@/layouts/Layout.astro';

const title = 'Products: SoundIn | Software We Build and Own';
const description = 'Holocron is live and in production with paying customers. Compliance-first venue management for UK nightlife operators.';

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://soundin.scot/ecosystem#webpage',
  name: title,
  description,
  url: 'https://soundin.scot/ecosystem',
  isPartOf: { '@id': 'https://soundin.scot/#organization' },
};
---

<Layout
  title={title}
  description={description}
  canonical="https://soundin.scot/ecosystem"
  current="ecosystem"
  skipLink={{ href: '#ecosystem-content', label: 'Skip to products' }}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(collectionSchema)} slot="head" />

  <main class="eco" id="ecosystem-content" tabindex="-1">
    <header class="eco-head">
      <h1>Products</h1>
      <p class="eco-intro">What we build and own.</p>
    </header>

    <article class="product" id="holocron">
      <div class="product-top">
        <h2 class="product-name">Holocron</h2>
        <span class="product-status">Live</span>
      </div>
      <p class="product-desc">
        Compliance-first venue management for UK nightlife operators. Attendance, ticketing, incidents, guest lists, financial settlements&nbsp;&mdash; without the spreadsheets.
      </p>
      <a
        href="https://holocron.scot"
        rel="noopener noreferrer"
        target="_blank"
        class="product-link"
      >
        Visit holocron.scot <span aria-hidden="true">↗</span>
      </a>
    </article>

    <div class="eco-pipeline">
      <p>More products are in development. Announcements go to the newsletter first&nbsp;&mdash; not a press release, not a Product Hunt post.</p>
      <a href="/newsletter" class="cta-button">Subscribe <span aria-hidden="true">&rarr;</span></a>
    </div>
  </main>
</Layout>

<style>
  .eco {
    max-width: 700px;
    margin: 0 auto;
    padding: 180px 32px 120px;
  }

  .eco-head {
    margin-bottom: 72px;
  }

  .eco-head h1 {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    font-size: clamp(40px, 5vw, 64px);
    line-height: 1.05;
    color: var(--color-snow);
    margin-bottom: 12px;
  }

  .eco-intro {
    font-family: var(--font-sans);
    font-size: 16px;
    color: var(--color-muted);
  }

  /* Product */
  .product {
    padding: 48px 0;
    border-top: 1px solid var(--color-ghost);
  }

  .product-top {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 20px;
  }

  .product-name {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    font-size: clamp(28px, 4vw, 44px);
    color: var(--color-salmon);
    line-height: 1.1;
  }

  .product-status {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    border: 1px solid var(--color-faint);
    border-radius: 999px;
    padding: 3px 8px;
  }

  .product-desc {
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.75;
    color: var(--color-cream);
    margin-bottom: 28px;
    max-width: 560px;
  }

  .product-link {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-snow);
    border-bottom: 1px solid var(--color-faint);
    padding-bottom: 3px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.3s ease, border-color 0.3s ease, gap 0.3s ease;
  }

  .product-link:hover {
    color: var(--color-salmon);
    border-bottom-color: var(--color-salmon);
    gap: 10px;
  }

  .product-link:focus-visible {
    outline: 2px solid var(--color-salmon);
    outline-offset: 4px;
    border-radius: 2px;
  }

  /* Pipeline CTA */
  .eco-pipeline {
    padding: 48px 0;
    border-top: 1px solid var(--color-ghost);
  }

  .eco-pipeline p {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-muted);
    margin-bottom: 28px;
    max-width: 480px;
  }

  @media (max-width: 600px) {
    .eco { padding: 140px 24px 80px; }
    .product-name { font-size: clamp(26px, 8vw, 36px); }
  }
</style>
