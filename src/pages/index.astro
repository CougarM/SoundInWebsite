---
import Layout from '@/layouts/Layout.astro';

const title = 'SoundIn — Scottish Digital Agency | Web, Events & Venue Software';
const description = 'SoundIn is a Scottish Highlands digital agency building web applications, venue management software, DMX lighting systems, and event production. Tell us what you’re looking for.';

type Pill = {
  label: string;
  href: string;
  external?: boolean;
  icon: 'compass' | 'practices' | 'holocron' | 'events' | 'mail' | 'shuffle';
};

const pills: Pill[] = [
  { label: 'our story', href: '/vision', icon: 'compass' },
  { label: 'practices', href: '/practices', icon: 'practices' },
  { label: 'holocron', href: 'https://holocron.scot', external: true, icon: 'holocron' },
  { label: 'events', href: '/practices#events', icon: 'events' },
  { label: 'contact', href: '/contact', icon: 'mail' },
  { label: 'surprise me', href: '#surprise', icon: 'shuffle' },
];

const orgSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['Organization', 'LocalBusiness'],
      '@id': 'https://soundin.scot/#organization',
      name: 'SoundIn',
      legalName: 'SoundIn Limited',
      url: 'https://soundin.scot',
      email: 'hello@soundin.scot',
      foundingDate: '2025',
      description: 'Scottish Highlands digital agency delivering web development, venue management software, DMX lighting systems, event production, and social media management for purpose-driven businesses.',
      identifier: { '@type': 'PropertyValue', name: 'Companies House', value: 'SC850719' },
      address: { '@type': 'PostalAddress', addressRegion: 'Highland', addressCountry: 'GB' },
      areaServed: [
        { '@type': 'Country', name: 'United Kingdom' },
        { '@type': 'AdministrativeArea', name: 'Scotland' },
      ],
      knowsAbout: ['Web Development', 'Digital Marketing', 'Event Production', 'Venue Management Software', 'DMX Lighting Control', 'Social Media Management'],
      sameAs: ['https://www.linkedin.com/company/soundin-ltd'],
    },
  ],
};
---

<Layout
  title={title}
  description={description}
  canonical="https://soundin.scot/"
  chrome="minimal"
  skipLink={{ href: '#portal-search', label: 'Skip to search' }}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} slot="head" />

  <main class="portal">
    <!-- Topographic backdrop -->
    <svg
      class="portal-topo"
      aria-hidden="true"
      viewBox="0 0 1440 900"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="xMidYMid slice"
    >
      <path d="M-40 740 C220 700, 460 760, 680 700 C880 650, 1060 720, 1260 660 C1380 620, 1480 680, 1540 650" stroke="rgba(231,223,217,0.05)" stroke-width="1.2" fill="none"/>
      <path d="M-40 620 C200 570, 400 640, 620 580 C820 520, 1000 600, 1200 540 C1340 490, 1460 550, 1540 520" stroke="rgba(231,223,217,0.05)" stroke-width="1.2" fill="none"/>
      <path d="M-40 500 C180 460, 360 520, 580 450 C760 390, 940 470, 1140 410 C1300 360, 1420 420, 1540 390" stroke="rgba(231,223,217,0.05)" stroke-width="1.2" fill="none"/>
      <path d="M-40 380 C210 330, 440 400, 640 330 C820 270, 1000 350, 1200 290 C1340 250, 1460 310, 1540 280" stroke="rgba(231,223,217,0.04)" stroke-width="1.2" fill="none"/>
      <path d="M-40 270 C190 240, 380 280, 580 230 C760 190, 960 250, 1160 200 C1310 170, 1440 210, 1540 190" stroke="rgba(231,223,217,0.03)" stroke-width="1" fill="none"/>
      <path d="M-40 560 C200 510, 420 580, 640 510 C840 450, 1020 530, 1220 470 C1360 420, 1470 490, 1540 460" stroke="rgba(255,127,107,0.04)" stroke-width="1.8" fill="none"/>
      <circle cx="620" cy="510" r="2.5" fill="rgba(255,127,107,0.18)"/>
      <circle cx="1140" cy="410" r="2" fill="rgba(255,127,107,0.12)"/>
      <text x="1340" y="840" fill="rgba(231,223,217,0.08)" font-family="'Lexend Deca', sans-serif" font-size="10" font-weight="400" letter-spacing="0.08em">57.48&deg;N</text>
    </svg>

    <div class="portal-inner">
      <h1 class="portal-wordmark">
        <span class="logo-s">Sound</span><span class="logo-i">In</span>
      </h1>

      <p class="portal-tagline">
        <span class="gaelic">Fàilte.</span> What can we help you find?
      </p>

      <form id="portal-search" class="portal-search" role="search" aria-label="Site search">
        <span class="portal-search-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="7"/>
            <path d="m21 21-4.3-4.3"/>
          </svg>
        </span>
        <input
          id="portal-search-input"
          name="q"
          type="search"
          class="portal-search-input"
          placeholder="e.g. lighting, holocron, our story…"
          autocomplete="off"
          spellcheck="false"
          aria-label="Search the SoundIn site"
        />
        <span id="portal-search-hint" class="portal-search-hint" aria-live="polite"></span>
      </form>

      <ul class="portal-pills" aria-label="Quick links">
        {pills.map((p) => (
          <li>
            <a
              class="portal-pill"
              href={p.href}
              data-href={p.href}
              data-label={p.label}
              rel={p.external ? 'noopener noreferrer' : undefined}
              target={p.external ? '_blank' : undefined}
            >
              <span class="portal-pill-icon" aria-hidden="true">
                {p.icon === 'compass' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
                  </svg>
                )}
                {p.icon === 'practices' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="7" height="7"/>
                    <rect x="14" y="3" width="7" height="7"/>
                    <rect x="14" y="14" width="7" height="7"/>
                    <rect x="3" y="14" width="7" height="7"/>
                  </svg>
                )}
                {p.icon === 'holocron' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="9"/>
                    <circle cx="12" cy="12" r="4"/>
                    <line x1="12" y1="3" x2="12" y2="8"/>
                    <line x1="12" y1="16" x2="12" y2="21"/>
                  </svg>
                )}
                {p.icon === 'events' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                  </svg>
                )}
                {p.icon === 'mail' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="5" width="18" height="14" rx="2"/>
                    <polyline points="3 7 12 13 21 7"/>
                  </svg>
                )}
                {p.icon === 'shuffle' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="16 3 21 3 21 8"/>
                    <line x1="4" y1="20" x2="21" y2="3"/>
                    <polyline points="21 16 21 21 16 21"/>
                    <line x1="15" y1="15" x2="21" y2="21"/>
                    <line x1="4" y1="4" x2="9" y2="9"/>
                  </svg>
                )}
              </span>
              <span>{p.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <footer class="portal-foot" aria-label="Site meta">
      <span>SoundIn Limited · SC850719</span>
      <a href="/privacy">Privacy</a>
      <a href="https://www.linkedin.com/company/soundin-ltd" rel="noopener noreferrer" target="_blank">LinkedIn ↗</a>
    </footer>
  </main>
</Layout>

<style>
  body { background: var(--color-scarab); }

  .portal {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 64px 24px 24px;
    overflow: hidden;
  }

  .portal-topo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0;
    animation: portal-topo-enter 2.5s cubic-bezier(0.16, 1, 0.3, 1) 0.6s both;
  }

  @keyframes portal-topo-enter {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .portal-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 720px;
    text-align: center;
    margin: auto;
  }

  .portal-wordmark {
    font-family: var(--font-sans);
    font-size: clamp(64px, 12vw, 144px);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 0.95;
    color: var(--color-snow);
    margin: 0 0 32px;
    opacity: 0;
    animation: enter 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  .portal-wordmark .logo-s {
    font-family: var(--font-sans);
    font-weight: 900;
  }

  .portal-wordmark .logo-i {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    color: var(--color-salmon);
  }

  .portal-tagline {
    font-family: var(--font-serif);
    font-weight: 100;
    font-style: italic;
    font-size: clamp(20px, 2.4vw, 28px);
    color: rgba(231, 223, 217, 0.7);
    margin: 0 0 48px;
    opacity: 0;
    animation: enter 1s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }

  .portal-tagline .gaelic {
    color: var(--color-salmon);
  }

  /* Search */
  .portal-search {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    background: var(--color-snow);
    border-radius: 999px;
    padding: 4px 4px 4px 24px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25), 0 1px 0 rgba(255, 255, 255, 0.04);
    margin-bottom: 32px;
    opacity: 0;
    animation: enter 1s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .portal-search:focus-within {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), 0 0 0 3px rgba(255, 127, 107, 0.4);
  }

  .portal-search-icon {
    color: var(--color-scarab);
    opacity: 0.5;
    display: inline-flex;
    margin-right: 12px;
  }

  .portal-search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    padding: 16px 0;
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 400;
    color: var(--color-scarab);
    min-width: 0;
  }

  .portal-search-input::placeholder {
    color: rgba(36, 48, 44, 0.45);
    font-style: italic;
  }

  .portal-search-hint {
    position: absolute;
    bottom: -28px;
    left: 24px;
    right: 24px;
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-muted);
    text-align: left;
    pointer-events: none;
  }

  /* Pills */
  .portal-pills {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    opacity: 0;
    animation: enter 1s cubic-bezier(0.16, 1, 0.3, 1) 0.7s both;
  }

  .portal-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border: 1px solid rgba(231, 223, 217, 0.15);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 400;
    color: var(--color-snow);
    background: rgba(0, 0, 0, 0.15);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: border-color 0.3s ease, background 0.3s ease, transform 0.3s ease, color 0.3s ease;
  }

  .portal-pill:hover {
    border-color: var(--color-salmon);
    background: rgba(255, 127, 107, 0.12);
    color: var(--color-salmon);
    transform: translateY(-1px);
  }

  .portal-pill:focus-visible {
    outline: 2px solid var(--color-salmon);
    outline-offset: 4px;
  }

  .portal-pill-icon {
    display: inline-flex;
    color: currentColor;
    opacity: 0.8;
  }

  /* Footer meta */
  .portal-foot {
    position: relative;
    z-index: 1;
    margin-top: 64px;
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--color-muted);
    opacity: 0;
    animation: enter 1s cubic-bezier(0.16, 1, 0.3, 1) 0.9s both;
  }

  .portal-foot a { transition: color 0.3s ease; }
  .portal-foot a:hover { color: var(--color-snow); }
  .portal-foot a:focus-visible {
    color: var(--color-snow);
    outline: 2px solid var(--color-salmon);
    outline-offset: 4px;
    border-radius: 2px;
  }

  @media (max-width: 600px) {
    .portal { padding: 48px 16px 24px; }
    .portal-tagline { margin-bottom: 32px; }
    .portal-pills { gap: 8px; }
    .portal-pill { padding: 8px 14px; font-size: 13px; }
  }
</style>

<script>
  type Route = { keywords: string[]; href: string; label: string };

  const routes: Route[] = [
    { keywords: ['vision', 'story', 'about', 'mission', 'values', 'who', 'team', 'founders'], href: '/vision', label: 'our story' },
    { keywords: ['practice', 'practices', 'services', 'offerings', 'what'], href: '/practices', label: 'practices' },
    { keywords: ['holocron', 'venue', 'nightlife', 'club', 'ticketing', 'incidents'], href: 'https://holocron.scot', label: 'holocron' },
    { keywords: ['photon', 'lighting', 'dmx', 'lights'], href: '/practices#photon', label: 'photon' },
    { keywords: ['event', 'events', 'production', 'av', 'audio', 'sound'], href: '/practices#events', label: 'events' },
    { keywords: ['web', 'website', 'site', 'app', 'application', 'development', 'dev', 'frontend'], href: '/practices#web', label: 'web' },
    { keywords: ['social', 'marketing', 'instagram', 'tiktok', 'linkedin'], href: '/practices#social', label: 'social' },
    { keywords: ['contact', 'hello', 'talk', 'email', 'reach', 'enquire', 'enquiry'], href: '/contact', label: 'contact' },
    { keywords: ['privacy', 'gdpr', 'data'], href: '/privacy', label: 'privacy' },
  ];

  const input = document.getElementById('portal-search-input') as HTMLInputElement | null;
  const form = document.getElementById('portal-search') as HTMLFormElement | null;
  const hint = document.getElementById('portal-search-hint');

  function findRoute(query: string): Route | null {
    const q = query.toLowerCase().trim();
    if (!q) return null;
    for (const r of routes) {
      if (r.keywords.some((k) => q.includes(k))) return r;
    }
    return null;
  }

  function updateHint() {
    if (!input || !hint) return;
    const r = findRoute(input.value);
    hint.textContent = r ? `↵ go to ${r.label}` : '';
  }

  input?.addEventListener('input', updateHint);

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!input) return;
    const r = findRoute(input.value);
    if (r) {
      if (r.href.startsWith('http')) {
        window.open(r.href, '_blank', 'noopener');
      } else {
        window.location.href = r.href;
      }
    } else if (input.value.trim()) {
      window.location.href = '/practices';
    }
  });

  // Surprise me
  const surprisePill = document.querySelector<HTMLAnchorElement>('a[data-label="surprise me"]');
  surprisePill?.addEventListener('click', (e) => {
    e.preventDefault();
    const candidates = ['/vision', '/practices', '/practices#photon', '/practices#events', '/practices#holocron', '/contact'];
    const pick = candidates[Math.floor(Math.random() * candidates.length)];
    window.location.href = pick;
  });
</script>
